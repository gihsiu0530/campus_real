mpc_simulate/fast:
	cd /home/cyc/campus_ws/build && $(MAKE) $(MAKESILENT) -f mpc_4state/CMakeFiles/mpc_simulate.dir/build.make mpc_4state/CMakeFiles/mpc_simulate.dir/build
.PHONY : mpc_simulate/fast

